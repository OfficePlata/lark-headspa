{
  "name": "lark-headspa",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 SALON_DB",
    "pages:deploy": "pnpm build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 execute SALON_DB --local --file=./drizzle/migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute SALON_DB --remote --file=./drizzle/migrations/0001_init.sql",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^0.44.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "wouter": "^3.3.5",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.453.0",
    "sonner": "^2.0.7",
    "framer-motion": "^12.23.22",
    "date-fns": "^4.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "vitest": "^2.1.4",
    "wrangler": "^3.99.0"
  }
}
